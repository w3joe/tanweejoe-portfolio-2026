---
import AboutIntro from '@/components/about-intro.astro'
import BlogCard from '@/components/blog-card.astro'
import ExperienceSection from '@/components/experience-section.astro'
import HomeHero from '@/components/home-hero.astro'
import Link from '@/components/link.astro'
import PageHead from '@/components/page-head.astro'
import ProjectCard from '@/components/project-card.astro'
import PublicationCard from '@/components/publication-card.astro'
import { buttonVariants } from '@/components/ui/button'
import { SITE } from '@/consts'
import Layout from '@/layouts/layout.astro'
import { getAllProjects, getAllPublications, getRecentPosts } from '@/lib/data-utils'

const blog = await getRecentPosts(SITE.featuredPostCount)
const allProjects = await getAllProjects()
const featuredProjects = allProjects.slice(0, 4)
const publications = await getAllPublications()
---

<Layout class="max-w-3xl">
  <PageHead
    slot="head"
    titleIsComplete
    title="Tan Wee Joe — AI Research Engineer"
    structuredData
  />
  <HomeHero />

  <AboutIntro />

  <ExperienceSection />

  {
    publications.length > 0 && (
      <section class="flex flex-col gap-y-4">
        <h2 class="text-2xl font-medium">Research</h2>
        <div class="flex flex-col gap-4">
          {publications.map((pub) => (
            <PublicationCard publication={pub} />
          ))}
        </div>
      </section>
    )
  }

  <section class="flex flex-col gap-y-4">
    <div class="flex items-end justify-between gap-4">
      <h2 class="text-2xl font-medium">Works</h2>
      <Link
        href="/about"
        class={buttonVariants({ variant: 'ghost', size: 'sm' }) +
          ' group shrink-0'}
        id="view-all-works"
      >
        View all <span
          class="ml-1 transition-transform group-hover:translate-x-1"
          >&rarr;</span
        >
      </Link>
    </div>
    <div class="flex flex-col gap-4">
      {featuredProjects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <section class="flex flex-col gap-y-4">
    <h2 class="text-2xl font-medium">Latest posts</h2>
    <ul class="flex flex-col gap-y-4">
      {
        blog.length > 0 ? (
          blog.map((post) => (
            <li>
              <BlogCard entry={post} />
            </li>
          ))
        ) : (
          <li class="text-muted-foreground text-sm">
            No posts yet — check back soon.
          </li>
        )
      }
    </ul>
    <div class="flex justify-center">
      <Link
        href="/blog"
        class={buttonVariants({ variant: 'ghost' }) + ' group'}
        id="see-all-posts"
      >
        See all posts <span
          class="ml-1.5 transition-transform group-hover:translate-x-1"
          >&rarr;</span
        >
      </Link>
    </div>
  </section>
</Layout>

<script>
  function setupIndexLinks() {
    const viewAllWorks = document.getElementById(
      'view-all-works',
    ) as HTMLAnchorElement | null
    viewAllWorks?.removeEventListener(
      'click',
      (viewAllWorks as any).__posthogWorksClick,
    )
    ;(viewAllWorks as any).__posthogWorksClick = () => {
      window.posthog?.capture('view_all_works_clicked')
    }
    viewAllWorks?.addEventListener(
      'click',
      (viewAllWorks as any).__posthogWorksClick,
    )

    const seeAllPosts = document.getElementById(
      'see-all-posts',
    ) as HTMLAnchorElement | null
    seeAllPosts?.removeEventListener(
      'click',
      (seeAllPosts as any).__posthogPostsClick,
    )
    ;(seeAllPosts as any).__posthogPostsClick = () => {
      window.posthog?.capture('view_all_posts_clicked')
    }
    seeAllPosts?.addEventListener(
      'click',
      (seeAllPosts as any).__posthogPostsClick,
    )
  }

  document.addEventListener('astro:page-load', setupIndexLinks)
</script>
