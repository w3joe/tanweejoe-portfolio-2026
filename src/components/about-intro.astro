---
import { ABOUT_BODY, ABOUT_LEAD } from '@/data/about'
---

<section class="flex flex-col gap-6 sm:gap-8" aria-label="Introduction">
  <p
    class="text-foreground max-w-[min(100%,42rem)] text-[clamp(1.75rem,1.1rem+3.2vw,3.25rem)] leading-[1.12] font-bold tracking-[-0.03em] text-pretty"
  >
    {ABOUT_LEAD}
  </p>
  <p
    class="text-muted-foreground max-w-2xl text-base leading-relaxed text-pretty sm:text-lg"
  >
    {ABOUT_BODY}
  </p>
</section>
