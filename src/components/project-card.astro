---
import Link from '@/components/link.astro'
import { Badge } from '@/components/ui/badge'
import { Icon } from 'astro-icon/components'
import type { CollectionEntry } from 'astro:content'

interface Props {
  project: CollectionEntry<'projects'>
}

const { project } = Astro.props

let linkHost: string | null = null
try {
  linkHost = new URL(project.data.link).hostname.replace(/^www\./, '')
} catch {
  linkHost = null
}
---

<div class="glass group rounded-xl border transition-shadow hover:shadow-lg">
  <Link
    href={project.data.link}
    class="text-foreground flex flex-col justify-between gap-6 p-6 sm:p-7"
    external
    data-posthog-project-name={project.data.name}
    data-posthog-project-link={project.data.link}
  >
    <div class="min-w-0">
      <div class="flex items-start justify-between gap-4">
        <h3 class="text-lg font-semibold tracking-tight sm:text-xl">
          {project.data.name}
        </h3>
        <Icon
          name="lucide:arrow-up-right"
          class="text-muted-foreground group-hover:text-foreground mt-0.5 size-4 shrink-0 transition-colors"
        />
      </div>

      {
        linkHost && (
          <div class="text-muted-foreground mt-4 space-y-1 text-sm">
            <p class="text-muted-foreground/70 flex items-center gap-2">
              <Icon name="lucide:link-2" class="size-3.5" />
              <span class="truncate">{linkHost}</span>
            </p>
          </div>
        )
      }
    </div>

    <p
      class="text-muted-foreground text-sm leading-relaxed text-pretty sm:text-base"
    >
      {project.data.description}
    </p>

    {
      project.data.tags?.length > 0 && (
        <div class="flex flex-wrap gap-2 pt-1">
          {project.data.tags.map((tag: string) => (
            <Badge variant="muted">{tag}</Badge>
          ))}
        </div>
      )
    }
  </Link>
</div>

<script>
  function setupProjectCards() {
    document
      .querySelectorAll<HTMLAnchorElement>('a[data-posthog-project-name]')
      .forEach((card) => {
        card.removeEventListener('click', (card as any).__posthogClick)
        ;(card as any).__posthogClick = () => {
          window.posthog?.capture('project_link_clicked', {
            project_name: card.dataset.posthogProjectName,
            project_link: card.dataset.posthogProjectLink,
          })
        }
        card.addEventListener('click', (card as any).__posthogClick)
      })
  }

  document.addEventListener('astro:page-load', setupProjectCards)
</script>
