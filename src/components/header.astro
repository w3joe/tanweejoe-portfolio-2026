        <path d="M853,297.14v407a6.49,6.49,0,0,1-.31.59,1.17,1.17,0,0,1-.31.35L714.05,783.18a13.42,13.42,0,0,1-1.74.75c-.13.05-.3,0-.45,0a3.68,3.68,0,0,1-.35-.33,1.23,1.23,0,0,1-.19-.42,1.92,1.92,0,0,1-.11-.46c0-.16,0-.32,0-.48s0-.32,0-.48v-.48c0-.32,0-.64,0-1V763c0-.64,0-1.28,0-1.92,0-.48,0-1,0-1.44,0-.8,0-1.6.07-2.4,0-.48,0-1,0-1.44q0-15.84,0-31.68c0-1.44.07-2.87.07-4.31l.12-332.62v-1.44c0-.16,0-.32,0-.48s0-.32,0-.48,0-.32,0-.48,0-.31-.07-.47-.07-.31-.1-.47C708.93,381.57,584,309,579,306.53a5.89,5.89,0,0,0-1.66-.2c-1,92.72-1,185.3-1.67,277.88s-1,185.21-1.43,278l-76.05,44.57-72.51-43.52v-5q0-26.64-.07-53.27-.07-92.88-.13-185.75-.06-73-.17-145.91-.06-48.71-.19-97.43-.07-32.88-.18-65.75c0-1.58,0-3.17,0-4.58-1.82-.95-2.78.23-3.8.82-11.37,6.53-22.7,13.13-34,19.7l-93,53.9c-1.65,1-3.28,2-5.06,3V483.48q0,50.16,0,100.31,0,49.92.06,99.83,0,50.08.11,100.08c-.75.11-1.13.31-1.34.19-47-26-93.6-52.71-140.24-78.85-.55-4.24-.76-398.33-.26-407.51,1.12-1.49,3-2.18,4.59-3.13l108.74-63Q377.51,163.63,494.37,95.91c1.65-1,3.33-1.87,4.77-2.68a7.32,7.32,0,0,1,.77,0,1.28,1.28,0,0,1,.45.16l349,201.57C850.42,295.56,851.5,296.25,853,297.14Z"/>
      </svg>
    </Link>
    <div class="flex items-center gap-5">
      <nav class="flex items-center gap-5 text-sm">
        {
          NAV_LINKS.map((item) => {
            const isActive = pathname === item.href || (item.href !== '/' && pathname.startsWith(item.href))
            return (
              <Link
                href={item.href}
                class={`transition-colors ${isActive ? 'text-foreground font-medium' : 'text-muted-foreground hover:text-foreground'}`}
              >
                {item.label}
              </Link>
            )
          })
        }
      </nav>
      <ThemeToggle transition:persist />
    </div>
  </div>
</div>
