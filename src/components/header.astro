<div class="border-b border-border bg-background/95 text-foreground backdrop-blur-sm">
  <div class="page-gutter">
    <div class="page-frame flex items-center justify-between gap-4 py-4">
    <Link href="/" class="flex shrink-0 items-center gap-2.5 font-semibold tracking-tight">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1000 1000" fill="currentColor" class="size-7" aria-label="w3joe logo">
