---
import Link from '@/components/link.astro'
import ParticleFlowField from '@/components/particle-flow-field'
import { buttonVariants } from '@/components/ui/button'
import {
  HERO_CTA_PRIMARY,
  HERO_DESCRIPTION,
  HERO_DISPLAY_NAME,
  HERO_ROLE,
} from '@/data/hero'
import { cn } from '@/lib/utils'
---

<section
  class="border-border bg-background relative left-1/2 isolate -mt-10 mb-8 min-h-[min(92vh,58rem)] w-screen max-w-[100vw] -translate-x-1/2 overflow-hidden border-y"
  aria-label="Introduction"
>
  <ParticleFlowField client:load />

  <div
    class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_80%_50%_at_50%_-10%,color-mix(in_oklch,var(--foreground)_8%,transparent),transparent_55%)]"
    aria-hidden="true"
  >
  </div>

  <div
    class="page-frame relative z-10 flex min-h-[min(92vh,58rem)] flex-col pt-16 pb-14 sm:pt-20 sm:pb-16 lg:pt-24"
  >
    <div class="flex min-w-0 flex-1 flex-col">
      <div class="min-w-0">
        <div
          class="min-w-0 overflow-x-auto [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
        >
          <h1
            class="text-foreground w-max max-w-none font-sans text-[clamp(2rem,min(11vw,12vh),8.5rem)] leading-[0.9] font-bold tracking-[-0.045em] whitespace-nowrap uppercase sm:leading-[0.88]"
          >
            {HERO_DISPLAY_NAME}
          </h1>
        </div>
        <p class="text-foreground mt-4 text-xl font-medium sm:mt-5 sm:text-2xl">
          {HERO_ROLE}
        </p>
        <p
          class="text-muted-foreground mt-8 max-w-2xl text-base leading-relaxed text-pretty sm:text-lg lg:max-w-xl xl:max-w-2xl"
        >
          {HERO_DESCRIPTION}
        </p>

        <Link
          href={HERO_CTA_PRIMARY.href}
          class={cn(
            buttonVariants({ variant: 'default', size: 'lg' }),
            'mt-10',
          )}
          id="hero-cta"
          data-posthog-cta-label={HERO_CTA_PRIMARY.label}
          data-posthog-cta-href={HERO_CTA_PRIMARY.href}
        >
          {HERO_CTA_PRIMARY.label}
        </Link>
      </div>
    </div>
  </div>
</section>

<script>
  function setupHeroCta() {
    const cta = document.getElementById('hero-cta') as HTMLAnchorElement | null
    if (!cta) return
    cta.removeEventListener('click', (cta as any).__posthogCtaClick)
    ;(cta as any).__posthogCtaClick = () => {
      window.posthog?.capture('hero_cta_clicked', {
        label: cta.dataset.posthogCtaLabel,
        href: cta.dataset.posthogCtaHref,
      })
    }
    cta.addEventListener('click', (cta as any).__posthogCtaClick)
  }

  document.addEventListener('astro:page-load', setupHeroCta)
</script>
